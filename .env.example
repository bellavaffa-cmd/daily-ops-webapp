# Copy this to .env and fill in the token below.
# Then run:  source .env && python3 sync_ops.py

# Logiwa session token — get from:
#   1. Open wms.golocad.com in Chrome
#   2. Cmd+Option+I → Application → Local Storage → wms.golocad.com
#   3. Copy the value of the key "token"
export LOGIWA_TOKEN=paste-your-logiwa-token-here
